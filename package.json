{
  "name": "ak-software",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main.js",

  "scripts": {
    "dev": "concurrently \"npm run next-dev\" \"npm run electron-dev\"",

    "next-dev": "next dev",

    "electron-dev": "wait-on tcp:3000 && npm run build:electron && cross-env NODE_ENV=development electron .",

    "build:electron": "tsup electron/main.ts electron/preload.ts --format cjs --out-dir dist-electron --external electron",

    "electron-build": "electron-builder",

    "build": "next build && npm run build:electron",

    "dist": "npm run build && electron-builder",

    "start": "next start",

    "lint": "eslint",
    "prisma":"tsx prisma/seed.ts"
  },

  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^5.22.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.25",
    "archiver": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "date-fns": "^4.2.1",
    "dotenv": "^17.4.2",
    "extract-zip": "^2.0.1",
    "fs-extra": "^11.3.5",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "prisma": "^5.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.76.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.8.0",
    "sonner": "^2.0.7",
    "sqlite3": "^6.0.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "wait-on": "^9.0.10",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },

  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.41",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "electron": "^30.0.9",
    "electron-builder": "^26.8.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsup": "^8.5.1",
    "typescript": "^5"
  },

  "buildConfig": {
    "appId": "com.aksoftware.pos",

    "productName": "AK Software",

    "directories": {
      "output": "release"
    },

    "files": [
      "dist-electron/**/*",

      ".next/standalone/**/*",

      ".next/static/**/*",

      "public/**/*",

      "prisma/**/*",

      "database/**/*",

      "package.json"
    ],

    "extraResources": [
      {
        "from": "database",
        "to": "database"
      }
    ],

    "asarUnpack": [
      "**/*.node",

      "node_modules/.prisma/**/*",

      "node_modules/@prisma/**/*"
    ],

    "win": {
      "target": "nsis"
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}